{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "taara-connect",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "redis": true,
    "reddit": {
      "scope": "user",
      "asUser": ["SUBMIT_COMMENT"]
    }
  },
  "menu": {
    "items": [
      {
        "label": "Open tonight’s sky",
        "description": "Create tonight’s TaaraNight puzzle post by hand",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      }
    ]
  },
  "scheduler": {
    "tasks": {
      "nightly-post": {
        "endpoint": "/internal/scheduler/nightly-post",
        "cron": "0 1 * * *"
      }
    }
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "dev": {
    "subreddit": "taara_connect_dev"
  }
}